# ============================================================
# 广州大学成绩监测系统 — 环境配置
# 复制此文件为 .env：cp .env.example .env
# 然后打开 .env 填入你的真实信息
# ============================================================

# ---- 教务系统登录 ----
GZHU_USERNAME=你的学号
GZHU_PASSWORD=你的教务系统密码

# ---- QQ 邮箱 SMTP 发信 ----
# 需要去 QQ 邮箱网页版 → 设置 → 账户 → 开启 SMTP 服务获取授权码
# 授权码是一串字母，不是 QQ 密码！
QQ_EMAIL=你的QQ邮箱@qq.com
QQ_AUTH_CODE=你的SMTP授权码

# ---- 通知接收 ----
# 接收成绩通知的邮箱，多个邮箱用英文逗号分隔
RECEIVER_EMAILS=receiver1@example.com,receiver2@example.com
# 测试邮件收件人，不填则默认发到上面配置的邮箱
TEST_EMAIL=test_receiver@example.com

# ---- 监测参数 ----
CHECK_INTERVAL=300            # 成绩检查间隔（秒），300 = 5分钟
EMAIL_SUBJECT=新成绩通知       # 通知邮件标题
ENABLE_LOGIN_TEST_EMAIL=true  # 登录后是否发送测试邮件，改 false 关闭

# ---- 心跳邮件（定期发邮件确认程序还在正常运行）----
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL=86400      # 心跳间隔（秒），86400 = 24小时
