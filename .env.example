# ============================================================
# 广州大学成绩监测系统 — 环境配置
# 复制此文件为 .env 并填入真实值：cp .env.example .env
# ============================================================

# ---- 教务系统登录 ----
GZHU_USERNAME=your_student_id
GZHU_PASSWORD=your_password

# ---- QQ 邮箱 SMTP ----
QQ_EMAIL=your_email@qq.com
QQ_AUTH_CODE=your_smtp_auth_code

# ---- 通知接收 ----
RECEIVER_EMAILS=receiver1@example.com,receiver2@example.com
TEST_EMAIL=test_receiver@example.com

# ---- 监测参数 ----
CHECK_INTERVAL=21600          # 成绩检查间隔，秒（21600 = 6小时）
EMAIL_SUBJECT=新成绩通知
ENABLE_LOGIN_TEST_EMAIL=true  # 登录后是否发送测试邮件

# ---- 心跳邮件（确认程序正常运行）----
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL=86400      # 心跳间隔，秒（86400 = 24小时）
